# WalletConnect Cloud project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ERC-721 NFT contract address (Ethereum mainnet) used for token gating
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x8fBb231840BeDF8a49080Ac3001B9c97BF35f4E9

# Alchemy API key — get one at https://dashboard.alchemy.com
# Used to fetch specific token IDs held by a wallet (getNFTsForOwner)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Public-facing app URL (used for share cards / OG meta)
NEXT_PUBLIC_APP_URL=http://localhost:3000
