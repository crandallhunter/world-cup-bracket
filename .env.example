# WalletConnect Cloud project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ERC-721 NFT contract address (Ethereum mainnet) used for token gating
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x8fBb231840BeDF8a49080Ac3001B9c97BF35f4E9

# Alchemy API key — get one at https://dashboard.alchemy.com
# Used to fetch specific token IDs held by a wallet (getNFTsForOwner)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Public-facing app URL (used for share cards / OG meta)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Server-only (not exposed to the browser) ────────────────────────────────

# PostgreSQL connection string
# Dev: Supabase connection string (Project Settings → Database → Connection string)
# Prod: AWS RDS / Aurora Postgres connection string
# Format: postgres://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# API-Football key — used by the daily score-update cron
# Get one at https://dashboard.api-football.com
APISPORTS_KEY=

# Shared secret used by the local/dev cron route at /api/cron/update-scores
# (Production runs as an AWS Lambda triggered by EventBridge — see
# lambdas/update-scores/index.ts — and doesn't use this secret.)
CRON_SECRET=
